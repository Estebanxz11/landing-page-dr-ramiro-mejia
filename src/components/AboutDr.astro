---
---

<section class="relative py-24 overflow-hidden bg-gradient-to-b from-sky-50 to-white">
  <!-- Decorative blob -->
  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-96 h-96 bg-sky-200/30 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Photo card -->
      <div class="flex justify-center reveal-left">
        <div class="relative max-w-sm w-full">
          <!-- Gradient ring -->
          <div class="absolute -inset-3 bg-gradient-to-br from-sky-500/30 via-sky-800/10 to-transparent rounded-3xl blur-xl"></div>

          <div class="relative glass rounded-3xl overflow-hidden shadow-2xl shadow-sky-900/40">
            <!-- Headshot placeholder -->
            <div class="w-full h-[28rem] bg-gradient-to-br from-sky-50 to-sky-100 flex flex-col items-center justify-center relative border border-sky-100">
              <div class="absolute inset-0 opacity-5" style="background: radial-gradient(circle at 70% 20%, #0ea5e9, transparent 60%)"></div>
              <div class="w-28 h-28 rounded-full bg-sky-100 border-2 border-sky-300 flex items-center justify-center mb-4 animate-float">
                <svg viewBox="0 0 64 64" class="w-14 h-14 text-sky-500" fill="currentColor">
                  <circle cx="32" cy="20" r="12" opacity="0.8"/>
                  <path d="M10 56c0-12.15 9.85-22 22-22s22 9.85 22 22" opacity="0.6"/>
                </svg>
              </div>
              <p class="text-sky-600 font-display text-xl font-semibold">Dr. Ramiro Mejía</p>
              <p class="text-slate-400 text-sm mt-1">Foto del Doctor</p>
            </div>

            <!-- Bottom info strip -->
            <div class="p-5 bg-gradient-to-br from-sky-50 to-white border-t border-sky-100">
              <div class="flex items-center gap-3">
                <div class="flex-1">
                <p class="text-slate-700 font-semibold text-sm">Ortodoncista Especialista</p>
                <p class="text-sky-500 text-xs mt-0.5">Universidad — SCO Certificado</p>
                </div>
                <div class="flex gap-1.5">
                  {[1,2,3,4,5].map(() => (
                    <svg class="w-3.5 h-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118L10 13.347l-2.807 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L3.56 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Floating achievements -->
          <div class="absolute -right-6 top-12 glass border border-sky-100 rounded-2xl px-4 py-3 shadow-lg w-44">
            <div class="flex items-center gap-2">
                <div class="w-9 h-9 rounded-full bg-sky-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sky-500" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
                </svg>
              </div>
              <div>
                <p class="text-slate-700 text-xs font-bold">15 años</p>
                <p class="text-slate-400 text-xs">Docente Posgrado</p>
              </div>
            </div>
          </div>

          <div class="absolute -left-6 bottom-20 glass border border-sky-100 rounded-2xl px-4 py-3 shadow-lg w-44">
            <div class="flex items-center gap-2">
              <div class="w-9 h-9 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <p class="text-slate-700 text-xs font-bold">Pionero</p>
                <p class="text-slate-400 text-xs">Ortod. Invisible EJE</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Bio -->
      <div class="reveal-right">
        <div class="inline-flex items-center gap-2 glass border border-sky-200 rounded-full px-4 py-2 mb-6">
          <span class="w-2 h-2 bg-sky-500 rounded-full animate-pulse"></span>
          <span class="text-sky-600 text-xs font-medium tracking-widest uppercase">Conóceme</span>
        </div>

        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-800 leading-tight mb-2">
          Ortodoncista
        </h2>
        <h2 class="font-display text-3xl sm:text-4xl font-bold gradient-text leading-tight mb-6">
          Ramiro Mejía
        </h2>

        <p class="text-slate-600 text-base leading-relaxed mb-5">
          Soy ortodoncista con <strong class="text-sky-400">más de 30 años de experiencia</strong>, pionero en el Eje
          Cafetero en ortodoncia invisible y ex presidente de la
          <strong class="text-sky-400">Sociedad Colombiana de Ortodoncia</strong> (2018–2020).
        </p>
        <p class="text-slate-500 text-sm leading-relaxed mb-8">
          Mi práctica combina experiencia clínica y tecnología moderna para
          ofrecer tratamientos precisos, estéticos y personalizados.
          Cada sonrisa es única y merece un plan de tratamiento a la medida.
        </p>

        <!-- Key points -->
        <ul class="space-y-3 mb-8">
          {[
            'Pionero en ortodoncia invisible en el Eje Cafetero',
            'Ex Presidente SCO (Sociedad Colombiana de Ortodoncia) 2018–2020',
            '15 años como docente de posgrado en la UAM',
            'Tecnología moderna para resultados precisos y estéticos',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-sky-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-sky-500" viewBox="0 0 12 12" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.22 2.22a.75.75 0 011.06 1.06l-6.5 6.5a.75.75 0 01-1.06 0l-3-3a.75.75 0 011.06-1.06l2.47 2.47 5.97-5.97z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-slate-600 text-sm">{item}</span>
            </li>
          ))}
        </ul>

        <a
          href="#agenda"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-400 hover:to-sky-500 text-white font-semibold rounded-full shadow-lg shadow-sky-200 transition-all duration-300 hover:scale-105 group"
        >
          Agenda tu Cita
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  .animate-float { animation: float 4s ease-in-out infinite; }
</style>
