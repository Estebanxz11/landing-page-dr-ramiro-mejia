---
---

<section id="agenda" class="relative py-24 overflow-hidden">
  <!-- Rich gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-sky-50 via-white to-sky-50">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-64 bg-sky-200/40 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-sky-100/60 rounded-full blur-[100px]"></div>
  </div>
  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(14,165,233,1) 1px, transparent 1px), linear-gradient(90deg, rgba(14,165,233,1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <div class="inline-flex items-center gap-2 glass border border-sky-200 rounded-full px-4 py-2 mb-4">
        <span class="w-2 h-2 bg-sky-500 rounded-full animate-pulse"></span>
        <span class="text-sky-600 text-xs font-medium tracking-widest uppercase">Agenda tu Cita</span>
      </div>
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-800 leading-tight">
        ¿Listo para <span class="gradient-text">transformar</span><br/>tu sonrisa?
      </h2>
      <p class="mt-5 text-slate-500 max-w-xl mx-auto text-base leading-relaxed">
        Si estás pensando en iniciar un tratamiento de ortodoncia o quieres una valoración profesional,
        estamos aquí para ayudarte.
      </p>
    </div>

    <!-- Contact options grid -->
    <div class="grid sm:grid-cols-3 gap-5 mb-12 stagger">
      <!-- WhatsApp -->
      <a
        href="https://wa.me/573138408082"
        target="_blank"
        rel="noopener"
        class="group glass border border-green-200 hover:border-green-400 rounded-3xl p-7 flex flex-col items-center gap-4 text-center transition-all duration-300 hover:-translate-y-2 hover:bg-green-50 hover:shadow-xl hover:shadow-green-100 reveal-scale"
      >
          <div class="w-16 h-16 rounded-2xl bg-green-100 flex items-center justify-center transition-transform group-hover:scale-110">
          <svg class="w-8 h-8 text-green-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div>
          <p class="text-slate-800 font-semibold mb-1">WhatsApp</p>
          <p class="text-green-600 font-mono text-sm font-medium">313 840 8082</p>
          <p class="text-slate-400 text-xs mt-1">Respuesta inmediata</p>
        </div>
      </a>

      <!-- Instagram -->
      <a
        href="https://www.instagram.com/ortodoncistaramiromejia/"
        target="_blank"
        rel="noopener"
        class="group glass border border-pink-200 hover:border-pink-400 rounded-3xl p-7 flex flex-col items-center gap-4 text-center transition-all duration-300 hover:-translate-y-2 hover:bg-pink-50 hover:shadow-xl hover:shadow-pink-100 reveal-scale"
        style="transition-delay:0.1s"
      >
          <div class="w-16 h-16 rounded-2xl bg-pink-100 flex items-center justify-center transition-transform group-hover:scale-110">
          <svg class="w-8 h-8 text-pink-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <div>
          <p class="text-slate-800 font-semibold mb-1">Instagram</p>
          <p class="text-pink-600 text-sm font-medium">@ortodoncistaramiromejia</p>
          <p class="text-slate-400 text-xs mt-1">Núnete a nuestra comunidad</p>
        </div>
      </a>

      <!-- TikTok -->
      <a
        href="https://www.tiktok.com/@ramiromejiaortodoncista"
        target="_blank"
        rel="noopener"
        class="group glass border border-slate-200 hover:border-slate-400 rounded-3xl p-7 flex flex-col items-center gap-4 text-center transition-all duration-300 hover:-translate-y-2 hover:bg-slate-50 hover:shadow-xl reveal-scale"
        style="transition-delay:0.2s"
      >
          <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center transition-transform group-hover:scale-110">
            <svg class="w-8 h-8 text-slate-700" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.69a4.86 4.86 0 01-1.01-.0z"/>
          </svg>
        </div>
        <div>
          <p class="text-slate-800 font-semibold mb-1">TikTok</p>
          <p class="text-slate-600 text-sm font-medium">@ramiromejiaortodoncista</p>
          <p class="text-slate-400 text-xs mt-1">Contenido educativo</p>
        </div>
      </a>
    </div>

    <!-- Main CTA + Location -->
    <div class="grid lg:grid-cols-2 gap-6 reveal" style="transition-delay:0.3s">
      <!-- CTA Card -->
      <div class="glass border border-sky-200 rounded-3xl p-8 text-center bg-gradient-to-br from-sky-50 to-white">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-sky-100 flex items-center justify-center mb-5">
          <svg class="w-8 h-8 text-sky-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <polyline points="9 16 11 18 15 14"/>
          </svg>
        </div>
        <h3 class="font-display text-2xl font-bold text-slate-800 mb-3">Valoración Profesional</h3>
        <p class="text-slate-500 text-sm mb-7 leading-relaxed">
          El primer paso hacia tu sonrisa ideal comienza con una valoración. Agenda hoy mismo y descubre el plan perfecto para ti.
        </p>
        <a
          href="https://wa.me/573138408082?text=Hola%20Dr.%20Ramiro%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita%20de%20valoraci%C3%B3n."
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-400 hover:to-sky-500 text-white font-bold rounded-2xl shadow-lg shadow-sky-200 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-sky-300 text-base"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.940 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.570-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.050 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar Cita de Valoración
        </a>
      </div>

      <!-- Location Card -->
      <div class="glass border border-sky-100 rounded-3xl overflow-hidden shadow-sm">
        <!-- Map placeholder -->
          <div class="h-48 bg-gradient-to-br from-sky-100 to-sky-200 flex items-center justify-center relative">
          <!-- Decorative map pattern -->
          <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 30px, rgba(14,165,233,0.4) 30px, rgba(14,165,233,0.4) 31px), repeating-linear-gradient(90deg, transparent, transparent 30px, rgba(14,165,233,0.4) 30px, rgba(14,165,233,0.4) 31px);"></div>
          <div class="text-center z-10">
            <div class="w-10 h-10 bg-sky-500 rounded-full flex items-center justify-center mx-auto mb-2 shadow-lg shadow-sky-500/40">
              <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <a
              href="https://maps.app.goo.gl/NLjpgGBahGpP8Wyg7"
              target="_blank"
              rel="noopener"
              class="text-sky-400 text-xs font-medium hover:underline"
            >
              Ver en Google Maps
            </a>
          </div>
        </div>
        <!-- Address info -->
          <div class="p-6 bg-white">
            <div class="flex items-start gap-3 mb-4">
              <div class="w-9 h-9 rounded-xl bg-sky-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-sky-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <p class="text-slate-800 font-semibold text-sm">Clínica Oraltec</p>
              <p class="text-slate-500 text-xs mt-0.5">Calle 14 #23-26, Local 104</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-green-600" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <p class="text-slate-800 font-semibold text-sm">313 840 8082</p>
              <p class="text-slate-500 text-xs mt-0.5">WhatsApp disponible</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
