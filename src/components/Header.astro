---
const navLinks = [
  { href: '#inicio',       label: 'Inicio' },
  { href: '#quienes-somos', label: 'Quiénes Somos' },
  { href: '#servicios',    label: 'Servicios' },
  // { href: '#blog',         label: 'Blog' },
  { href: '#agenda',       label: 'Agenda tu Cita' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-white/80 backdrop-blur-lg border-b border-sky-100 py-3 shadow-sm"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">

      <!-- Logo -->
      <a href="#inicio" class="flex items-center group">
        <img
          src="/images/logo.webp"
          alt="Dr. Ramiro Mejía - Ortodoncista"
          class="h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-300"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="relative px-4 py-2 text-sm font-medium text-slate-600 hover:text-sky-600 transition-colors group"
          >
            {link.label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-sky-500 group-hover:w-3/4 transition-all duration-300 rounded-full" />
          </a>
        ))}
      </nav>

      <!-- Social + CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/ortodoncistaramiromejia/"
          target="_blank"
          rel="noopener"
          class="w-8 h-8 rounded-full border border-slate-200 bg-white flex items-center justify-center text-sky-500 hover:text-sky-600 hover:border-sky-300 transition-all duration-300 hover:scale-110 shadow-sm"
          aria-label="Instagram"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>

        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@ramiromejiaortodoncista"
          target="_blank"
          rel="noopener"
          class="w-8 h-8 rounded-full border border-slate-200 bg-white flex items-center justify-center text-sky-500 hover:text-sky-600 hover:border-sky-300 transition-all duration-300 hover:scale-110 shadow-sm"
          aria-label="TikTok"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.69a4.86 4.86 0 01-1.01-.0z"/>
          </svg>
        </a>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/573138408082"
          target="_blank"
          rel="noopener"
          class="ml-2 px-5 py-2 bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold rounded-full shadow-md shadow-sky-500/40 transition-all duration-300 hover:scale-105"
        >
          Agendar Cita
        </a>
      </div>

      <!-- Mobile menu btn -->
      <button
        id="menu-btn"
        class="lg:hidden flex flex-col gap-1.5 p-2 text-slate-600 hover:text-sky-600 transition-colors"
        aria-label="Abrir menú"
      >
        <span class="w-6 h-0.5 bg-current rounded-full transition-all"></span>
        <span class="w-6 h-0.5 bg-current rounded-full transition-all"></span>
        <span class="w-4 h-0.5 bg-current rounded-full transition-all"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-sky-100">
      <nav class="flex flex-col gap-1 mt-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2.5 text-slate-600 hover:text-sky-600 hover:bg-sky-50 rounded-xl transition-all text-sm font-medium"
          >
            {link.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-3 mt-4 px-4">
        <a href="https://www.instagram.com/ortodoncistaramiromejia/" target="_blank" rel="noopener" class="text-sky-500 hover:text-sky-600 transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@ramiromejiaortodoncista" target="_blank" rel="noopener" class="text-sky-500 hover:text-sky-600 transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.69a4.86 4.86 0 01-1.01-.0z"/></svg>
        </a>
        <a href="https://wa.me/573138408082" target="_blank" rel="noopener" class="ml-auto px-5 py-2 bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold rounded-full shadow-md shadow-sky-500/40 transition-colors duration-300">Agendar Cita</a>
      </div>
    </div>
  </div>
</header>
