---
const services = [
  {
    icon: `<svg viewBox="0 0 64 64" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="16" width="44" height="34" rx="10" stroke="currentColor" stroke-width="3" fill="none"/>
      <path d="M22 30 Q32 24 42 30 Q32 36 22 30Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      <circle cx="32" cy="30" r="4" fill="currentColor" opacity="0.4"/>
    </svg>`,
    label: 'Ortodoncia Invisible',
  },
  {
    icon: `<svg viewBox="0 0 64 64" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="12" y="14" width="40" height="36" rx="9" stroke="currentColor" stroke-width="3"/>
      <rect x="22" y="24" width="6" height="14" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
      <rect x="30" y="22" width="6" height="16" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
      <rect x="38" y="25" width="5" height="12" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
      <path d="M15 42 Q32 50 49 42" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
    </svg>`,
    label: 'Ortodoncia Convencional',
  },
  {
    icon: `<svg viewBox="0 0 64 64" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M32 10 C20 10 14 20 14 30 C14 42 20 52 32 52 C44 52 50 42 50 30 C50 20 44 10 32 10Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <path d="M22 28 L42 28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M32 20 L32 40" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="47" cy="17" r="8" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="2"/>
      <path d="M44 17 L46 19 L50 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    label: 'Ortodoncia y Cirugía Maxilofacial',
  },
  {
    icon: `<svg viewBox="0 0 64 64" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M16 20 Q16 12 26 12 Q32 12 32 18 Q32 12 38 12 Q48 12 48 20 Q48 30 32 44 Q16 30 16 20Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      <path d="M26 28 L30 32 L38 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    label: 'Blanqueamiento Dental',
  },
  {
    icon: `<svg viewBox="0 0 64 64" class="w-8 h-8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 18 L20 46" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M20 18 Q24 12 30 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <circle cx="42" cy="34" r="12" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <path d="M42 28 L42 40 M36 34 L48 34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
    label: 'Higiene Oral',
  },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
>
  <!-- Animated background -->
  <div class="absolute inset-0 bg-gradient-to-br from-white via-sky-50 to-white">
    <!-- Glowing orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-sky-200/40 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-sky-100/60 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay:1.5s"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-sky-50/80 rounded-full blur-[180px]"></div>
  </div>

  <!-- Subtle grid overlay -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(rgba(14,165,233,1) 1px, transparent 1px), linear-gradient(90deg, rgba(14,165,233,1) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Floating dental particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    {[...Array(6)].map((_, i) => (
      <div
        class="absolute w-1 h-1 bg-sky-400 rounded-full opacity-30"
        style={`left:${10 + i*15}%; top:${20 + (i%3)*20}%; animation: float ${3 + i*0.5}s ease-in-out infinite; animation-delay:${i*0.4}s;`}
      ></div>
    ))}
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Text -->
      <div class="order-2 lg:order-1">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 glass border border-sky-200 rounded-full px-4 py-2 mb-6 reveal">
          <span class="w-2 h-2 bg-sky-500 rounded-full animate-pulse"></span>
          <span class="text-sky-600 text-xs font-medium tracking-widest uppercase">Más de 30 años de experiencia</span>
        </div>

        <!-- Heading -->
        <h1 class="font-display leading-tight mb-6 reveal" style="transition-delay:0.1s">
          <span class="text-4xl sm:text-5xl xl:text-6xl font-bold text-slate-900 block">Tu sonrisa</span>
          <span class="text-4xl sm:text-5xl xl:text-6xl font-bold gradient-text block">perfecta</span>
          <span class="text-3xl sm:text-4xl xl:text-5xl font-light text-slate-500 block mt-1">en el Eje Cafetero</span>
        </h1>

        <p class="text-slate-500 text-lg leading-relaxed mb-8 reveal max-w-lg" style="transition-delay:0.2s">
          Ortodoncia invisible y convencional con la precisión y experiencia que mereces.
          Somos pioneros en ortodoncia invisible en el Eje Cafetero.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-12 reveal" style="transition-delay:0.3s">
          <a
            href="#agenda"
            class="group px-7 py-3.5 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-400 hover:to-sky-500 text-white font-semibold rounded-full shadow-lg shadow-sky-200 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-sky-300 flex items-center gap-2"
          >
            Agenda tu Cita
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="#servicios"
            class="px-7 py-3.5 border border-sky-300 text-sky-600 hover:border-sky-500 hover:text-sky-700 hover:bg-sky-50 font-medium rounded-full transition-all duration-300"
          >
            Ver Servicios
          </a>
        </div>

        <!-- Stats -->
        <div class="flex gap-8 reveal stagger" style="transition-delay:0.4s">
          <div>
            <div class="text-3xl font-display font-bold gradient-text">30+</div>
            <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Años de experiencia</div>
          </div>
          <div class="w-px bg-sky-100"></div>
          <div>
            <div class="text-3xl font-display font-bold gradient-text">15</div>
            <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Años docente</div>
          </div>
          <div class="w-px bg-sky-100"></div>
          <div>
            <div class="text-3xl font-display font-bold gradient-text">SCO</div>
            <div class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Ex Presidente</div>
          </div>
        </div>
      </div>

      <!-- Right: Doctor visual card -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end reveal-right">
        <div class="relative">
          <!-- Glow ring -->
          <div class="absolute -inset-4 bg-gradient-to-br from-sky-500/20 to-sky-900/10 rounded-3xl blur-2xl"></div>

          <!-- Card -->
          <div class="relative glass rounded-3xl p-1 shadow-2xl shadow-sky-900/40">
            <!-- Doctor image placeholder -->
            <div class="w-72 h-96 sm:w-80 sm:h-[420px] rounded-2xl bg-gradient-to-br from-sky-100 to-sky-50 flex flex-col items-center justify-center overflow-hidden relative border border-sky-200">
              <!-- Abstract dental pattern -->
              <div class="absolute inset-0 opacity-10">
                <div class="absolute top-8 right-8 w-32 h-32 border-2 border-sky-400 rounded-full"></div>
                <div class="absolute top-16 right-16 w-20 h-20 border border-sky-300 rounded-full"></div>
                <div class="absolute bottom-8 left-8 w-24 h-24 border-2 border-sky-400 rounded-full"></div>
              </div>
              <!-- Icon placeholder -->
              <div class="w-24 h-24 rounded-full bg-sky-500/20 border-2 border-sky-400/30 flex items-center justify-center mb-4 animate-float">
                <svg viewBox="0 0 64 64" class="w-12 h-12 text-sky-400" fill="currentColor">
                  <circle cx="32" cy="20" r="10" opacity="0.8"/>
                  <path d="M14 52c0-9.94 8.06-18 18-18s18 8.06 18 18" opacity="0.6"/>
                </svg>
              </div>
              <p class="text-sky-700 text-sm font-medium">Dr. Ramiro Mejía</p>
              <p class="text-slate-400 text-xs mt-1">Inserta la foto del Dr. aquí</p>
            </div>

            <!-- Floating badge: Ex Presidente SCO -->
            <div class="absolute -bottom-4 -left-4 glass border border-sky-200 rounded-2xl px-4 py-2.5 shadow-lg">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-sky-100 rounded-full flex items-center justify-center">
                  <svg class="w-4 h-4 text-sky-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sky-800 text-xs font-bold">Ex Presidente SCO</p>
                  <p class="text-sky-600 text-xs">2018 – 2020</p>
                </div>
              </div>
            </div>

            <!-- Floating badge: Eje Cafetero -->
            <div class="absolute -top-4 -right-4 glass border border-sky-200 rounded-xl px-3 py-2 shadow-md">
              <div class="flex items-center gap-1.5">
                <span class="text-green-400 text-base">🌿</span>
                <div>
                  <p class="text-sky-700 text-xs font-bold leading-tight">Pionero</p>
                  <p class="text-sky-500 text-xs">Eje Cafetero</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Services icons strip -->
    <div class="mt-20 reveal" style="transition-delay:0.2s">
      <p class="text-center text-slate-400 uppercase text-xs tracking-widest mb-8">Nuestros Servicios</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 stagger">
        {services.map((s) => (
          <a
            href="#servicios"
            class="group glass border border-sky-100 hover:bg-sky-50 rounded-2xl p-5 flex flex-col items-center gap-3 text-center transition-all duration-300 hover:border-sky-400 hover:shadow-lg hover:shadow-sky-100 hover:-translate-y-1 reveal-scale"
          >
            <div class="text-sky-500 group-hover:text-sky-600 group-hover:scale-110 transition-all duration-300" set:html={s.icon} />
            <span class="text-slate-600 text-xs font-medium leading-tight">{s.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-slate-400 text-xs uppercase tracking-widest">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-sky-400/70 to-transparent"></div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  .animate-float { animation: float 4s ease-in-out infinite; }
</style>
