---
const services = [
  {
    img: '/images/ortodoncia invisible.svg',
    label: 'Ortodoncia Invisible',
  },
  {
    img: '/images/ortodoncia tradicional.svg',
    label: 'Ortodoncia Convencional',
  },
  {
    img: '/images/Cirugia maxilofacial.svg',
    label: 'Ortodoncia y Cirugía Maxilofacial',
  },
  {
    img: '/images/Blanqueamiento.svg',
    label: 'Blanqueamiento Dental',
  },
  {
    img: '/images/higiene oral.svg',
    label: 'Higiene Oral',
  },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
>
  <!-- Animated background -->
  <div class="absolute inset-0">
    <img src="/images/fondo-hero.svg" alt="" class="w-full h-full object-cover object-center" />
    <!-- Overlay negro elegante para máximo contraste del texto -->
    <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/60 to-black/85"></div>
    <!-- Tinte azul corporativo sutil encima del negro -->
    <div class="absolute inset-0 bg-gradient-to-tr from-[#355C98]/20 via-transparent to-[#355C98]/15"></div>
  </div>

  <!-- Subtle grid overlay -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(rgba(14,165,233,1) 1px, transparent 1px), linear-gradient(90deg, rgba(14,165,233,1) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Floating dental particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    {[...Array(6)].map((_, i) => (
      <div
        class="absolute w-1 h-1 bg-sky-400 rounded-full opacity-30"
        style={`left:${10 + i*15}%; top:${20 + (i%3)*20}%; animation: float ${3 + i*0.5}s ease-in-out infinite; animation-delay:${i*0.4}s;`}
      ></div>
    ))}
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Text -->
      <div class="order-2 lg:order-1">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 border border-white/30 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6 reveal">
          <span class="w-2 h-2 bg-sky-300 rounded-full animate-pulse"></span>
          <span class="text-sky-200 text-xs font-medium tracking-widest uppercase">Más de 30 años de experiencia</span>
        </div>

        <!-- Heading -->
        <h1 class="font-display leading-tight mb-6 reveal" style="transition-delay:0.1s">
          <span class="text-4xl sm:text-5xl xl:text-6xl font-bold text-white block">Tu sonrisa</span>
          <span class="text-4xl sm:text-5xl xl:text-6xl font-bold text-sky-300 block">perfecta</span>
          <span class="text-3xl sm:text-4xl xl:text-5xl font-light text-white/70 block mt-1">en el Eje Cafetero</span>
        </h1>

      

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-12 reveal" style="transition-delay:0.3s">
          <a
            href="https://wa.me/573138408082?text=Hola%20Dr.%20Ramiro%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita%20de%20valoraci%C3%B3n."
            target="_blank"
            rel="noopener"
            class="group px-7 py-3.5 bg-sky-500 hover:bg-sky-600 text-white font-semibold rounded-full shadow-lg shadow-sky-500/40 transition-all duration-300 hover:scale-105 flex items-center gap-2"
          >
            Agenda tu Cita
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
        
        </div>

        <!-- Stats -->
        <div class="flex items-start gap-8 reveal stagger" style="transition-delay:0.4s">
          <div>
            <div class="text-xs text-white/90 font-semibold uppercase tracking-wider">Años de experiencia</div>
            <div class="text-3xl font-display font-bold text-white leading-none mt-2">+30</div>
          </div>
          <div class="w-px h-14 bg-white/30 mt-1"></div>
          <div>
            <div class="text-xs text-white/90 font-semibold uppercase tracking-wider">Años docente</div>
            <div class="text-3xl font-display font-bold text-white leading-none mt-2">15</div>
          </div>
          <div class="w-px h-14 bg-white/30 mt-1"></div>
          <div>
            <div class="text-xs text-white/90 font-semibold uppercase tracking-wider">Ex Presidente</div>
            <div class="mt-2">
              <img src="/images/logosco.webp" alt="Sociedad Colombiana de Ortodoncia" class="h-12 w-auto object-contain" />
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Doctor visual card -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end reveal-right">
        <div class="relative">
          <!-- Glow ring -->
          <div class="absolute -inset-4 bg-gradient-to-br from-sky-500/20 to-sky-900/10 rounded-3xl blur-2xl"></div>

          <!-- Card -->
          <div class="relative glass rounded-3xl p-1 shadow-2xl shadow-sky-900/40">
            <!-- Doctor image placeholder -->
            <div class="w-72 h-96 sm:w-80 sm:h-[420px] rounded-2xl overflow-hidden relative border border-white/20">
              <img
                src="/images/doctor1.webp"
                alt="Dr. Ramiro Mejía - Ortodoncista"
                class="w-full h-full object-cover object-top"
              />
            </div>

            <!-- Floating badge: Ex Presidente SCO -->
            <div class="absolute -bottom-4 -left-4 glass border border-sky-200 rounded-2xl px-4 py-2.5 shadow-lg">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-sky-100 rounded-full flex items-center justify-center">
                  <svg class="w-4 h-4 text-sky-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sky-800 text-xs font-bold">Ex Presidente SCO</p>
                  <p class="text-sky-600 text-xs">2018 – 2020</p>
                </div>
              </div>
            </div>

            <!-- Floating badge: Eje Cafetero -->
            <div class="absolute -top-4 -right-4 glass border border-sky-200 rounded-xl px-3 py-2 shadow-md">
              <div class="flex items-center gap-1.5">
                <span class="text-green-400 text-base">🌿</span>
                <div>
                  <p class="text-sky-700 text-xs font-bold leading-tight">Pionero</p>
                  <p class="text-sky-500 text-xs">Eje Cafetero</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Services icons strip -->
    <div class="mt-20 reveal" style="transition-delay:0.2s">
      <p class="text-center text-white/90 font-semibold uppercase text-xs tracking-widest mb-8">Nuestros Servicios</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-5 stagger">
        {services.map((s) => (
          <a
            href="#servicios"
            class="group relative bg-white rounded-2xl p-5 flex flex-col items-center gap-4 text-center shadow-xl shadow-black/20 ring-1 ring-white/10 hover:ring-sky-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-sky-500/30 transition-all duration-300 reveal-scale overflow-hidden"
          >
            <!-- Halo decorativo en hover -->
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-28 h-28 bg-sky-200/0 group-hover:bg-sky-200/60 rounded-full blur-2xl transition-all duration-500"></div>

            <!-- Ícono circular -->
            <div class="relative w-16 h-16 rounded-full bg-gradient-to-br from-sky-50 to-sky-100 ring-1 ring-sky-200/60 group-hover:ring-sky-400 flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
              <img
                src={s.img}
                alt={s.label}
                loading="lazy"
                class="w-10 h-10 object-contain"
              />
            </div>

            <span class="relative text-slate-700 group-hover:text-sky-700 text-sm font-semibold leading-tight transition-colors">{s.label}</span>

            <!-- Línea decorativa que aparece al hover -->
            <span class="relative h-0.5 w-0 group-hover:w-10 bg-sky-500 rounded-full transition-all duration-500"></span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-white/40 text-xs uppercase tracking-widest">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-sky-400/70 to-transparent"></div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  .animate-float { animation: float 4s ease-in-out infinite; }
</style>
