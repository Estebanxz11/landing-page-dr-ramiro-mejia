---
const valores = ['Experiencia', 'Precisión', 'Tecnología', 'Ética', 'Compromiso', 'Innovación'];

const equipo = [
  { img: '/images/equipo3.webp', name: 'Dr. Ramiro Mejía', role: 'Ortodoncista · Director clínico' },
  { img: '/images/equipo2.webp', name: 'Cinthya Echeverry Toro',     role: 'Auxiliar de Ortodoncia' },
  { img: '/images/equipo4.webp', name: 'Vanessa Mendoza Hoyos',     role: 'Auxiliar de Ortodoncia' },
  { img: '/images/recepcionista.webp', name: 'Yineth Zulay Pineda Porras',     role: 'Recepcionista' },
];
---

<section id="quienes-somos" class="relative overflow-hidden bg-gradient-to-b from-white via-sky-50/40 to-white">

  <!-- Decorative blobs -->
  <div class="absolute right-0 top-40 w-80 h-80 bg-sky-100/60 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute left-0 bottom-40 w-72 h-72 bg-amber-100/40 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ============ 1. HEADER + QUOTE ============ -->
    <div class="pt-24 pb-16 text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 glass border border-sky-200 rounded-full px-4 py-2 mb-5 reveal">
        <span class="w-2 h-2 bg-sky-500 rounded-full animate-pulse"></span>
        <span class="text-sky-600 text-xs font-medium tracking-widest uppercase">Quiénes Somos</span>
      </div>

      <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-800 reveal" style="transition-delay:0.1s">
        Nuestro <span class="gradient-text">Equipo</span>
      </h2>

      <p class="mt-4 text-slate-500 max-w-2xl mx-auto text-base leading-relaxed reveal" style="transition-delay:0.2s">
        Un equipo de profesionales en salud oral comprometidos con tu bienestar y la excelencia clínica.
      </p>

      <!-- ====== Galería del equipo ====== -->
      <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-5 sm:gap-6">
        {equipo.map((m, i) => (
          <div class="group reveal flex flex-col items-center" style={`transition-delay:${0.1 + i * 0.08}s`}>
            <!-- Marco circular con anillo y hover -->
            <div class="relative">
              <!-- Anillo decorativo -->
              <div class="absolute -inset-1.5 rounded-full bg-gradient-to-tr from-sky-400 via-sky-200 to-amber-200 opacity-60 group-hover:opacity-100 blur-sm group-hover:blur-md transition-all duration-500"></div>

              <!-- Contenedor de la imagen -->
              <div class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden ring-4 ring-white shadow-xl shadow-sky-100/60 transition-all duration-500 group-hover:scale-110 group-hover:shadow-2xl group-hover:shadow-sky-200/70">
                <img
                  src={m.img}
                  alt={m.name}
                  loading="lazy"
                  class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
                />
                <!-- Overlay azul sutil al hover -->
                <div class="absolute inset-0 bg-gradient-to-t from-sky-600/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>

              <!-- Punto verde "disponible" -->
              <span class="absolute bottom-2 right-2 sm:bottom-3 sm:right-3 w-4 h-4 bg-green-400 border-2 border-white rounded-full shadow-md"></span>
            </div>

            <!-- Nombre + rol -->
            <div class="mt-5 text-center transition-transform duration-500 group-hover:-translate-y-1">
              <p class="font-display font-bold text-slate-800 text-sm sm:text-base leading-tight">{m.name}</p>
              <p class="text-sky-600 text-xs mt-1 font-medium">{m.role}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Quote sin caja, solo tipografía -->
      <div class="mt-12 reveal" style="transition-delay:0.3s">
        <svg class="w-10 h-10 mx-auto text-sky-200 mb-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M7.17 6C4.32 6 2 8.32 2 11.17v6.66h6.66v-6.66H5.33C5.33 8.86 7.17 7 9.5 7V6H7.17zm10 0c-2.85 0-5.17 2.32-5.17 5.17v6.66h6.66v-6.66h-3.33c0-2.31 1.84-4.17 4.17-4.17V6h-2.33z"/>
        </svg>
        <blockquote class="font-display text-2xl sm:text-3xl font-semibold text-slate-800 leading-snug italic">
          "Experiencia y compromiso real con los resultados de sus pacientes."
        </blockquote>
        <!-- <div class="mt-5 flex items-center justify-center gap-3">
          <div class="w-10 h-10 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-bold text-sm">RM</div>
          <div class="text-left">
            <p class="text-slate-800 font-semibold text-sm">Dr. Ramiro Mejía</p>
            <p class="text-slate-500 text-xs">Ortodoncista · Director clínico</p>
          </div>
        </div> -->
      </div>
    </div>

    <!-- ============ 2. STATS BAND ============ -->
    <div class="py-12 reveal">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 border-y border-sky-100 py-10">
        <div class="text-center">
          <div class="font-display text-3xl sm:text-4xl font-bold gradient-text">+30</div>
          <p class="mt-2 text-slate-500 text-xs sm:text-sm">Años de experiencia clínica</p>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl sm:text-4xl font-bold gradient-text">15</div>
          <p class="mt-2 text-slate-500 text-xs sm:text-sm">Años como docente de posgrado</p>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl sm:text-4xl font-bold gradient-text">2018 al 2020</div>
          <p class="mt-2 text-slate-500 text-xs sm:text-sm">Ex Presidente SCO (Sociedad Colombiana de Ortodoncia)</p>
        </div>
        <div class="text-center">
          <div class="font-display text-3xl sm:text-4xl font-bold gradient-text">1°</div>
          <p class="mt-2 text-slate-500 text-xs sm:text-sm">Pionero en ortodoncia invisible Eje Cafetero</p>
        </div>
      </div>
    </div>

    <!-- ============ 3. SECCIÓN: Liderazgo ============ -->
    <div class="py-16 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <span class="text-sky-600 text-xs font-semibold tracking-widest uppercase">01 · Liderazgo</span>
        <h3 class="font-display text-3xl sm:text-4xl font-bold text-slate-800 mt-3 leading-tight">
          Un equipo liderado con <span class="gradient-text">trayectoria</span>
        </h3>
        <p class="mt-5 text-slate-600 text-base leading-relaxed">
          Somos un equipo de profesionales en salud oral liderado por el
          <strong class="text-sky-700">Dr. Ramiro Mejía</strong>, ortodoncista con más de
          <strong class="text-slate-800">30 años de experiencia clínica</strong>, pionero en el Eje
          Cafetero en ortodoncia invisible y <strong class="text-slate-800">ex presidente de la
          Sociedad Colombiana de Ortodoncia (SCO)</strong> entre 2018 y 2020.
        </p>
      </div>

      <!-- Imagen cliente con animaciones -->
      <div class="reveal flex justify-center" style="transition-delay:0.1s">
        <div class="relative group w-80 sm:w-96">
          <!-- Blob animado fondo -->
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-sky-400 via-amber-200 to-sky-300 opacity-30 blur-2xl group-hover:opacity-60 transition-all duration-700 animate-pulse"></div>

          <!-- Contenedor imagen -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-sky-200/60 ring-4 ring-white
                      transition-all duration-500 group-hover:scale-[1.03] group-hover:shadow-sky-300/70 group-hover:shadow-2xl">
            <img
              src="/images/trabajando.webp"
              alt="Dr. Ramiro Mejía trabajando - Ortodoncista"
              loading="lazy"
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Overlay degradado sutil -->
            <div class="absolute inset-0 bg-gradient-to-t from-sky-900/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Badge flotante -->
            <div class="absolute bottom-4 left-4 right-4 flex items-center gap-2 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-2.5 shadow-lg
                        translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
              <span class="w-2.5 h-2.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
              <p class="text-slate-700 text-xs font-semibold leading-tight">Pacientes que confían en nuestra experiencia</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ============ 4. SECCIÓN: Academia (alterna) ============ -->
    <div class="py-16 grid lg:grid-cols-2 gap-12 items-center">
      <!-- Imagen estudiantes -->
      <div class="reveal flex justify-center order-2 lg:order-1" style="transition-delay:0.1s">
        <div class="relative group w-80 sm:w-96">
          <!-- Blob animado fondo -->
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-sky-300 via-sky-100 to-amber-200 opacity-30 blur-2xl group-hover:opacity-60 transition-all duration-700 animate-pulse"></div>

          <!-- Contenedor imagen -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-sky-200/60 ring-4 ring-white
                      transition-all duration-500 group-hover:scale-[1.03] group-hover:shadow-sky-300/70 group-hover:shadow-2xl">
            <img
              src="/images/estudiantes.webp"
              alt="Estudiantes de ortodoncia - Dr. Ramiro Mejía docente"
              loading="lazy"
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Overlay degradado sutil -->
            <div class="absolute inset-0 bg-gradient-to-t from-sky-900/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Badge -->
            <div class="absolute bottom-4 left-4 right-4 flex items-center gap-2 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-2.5 shadow-lg
                        translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
              <span class="w-2.5 h-2.5 rounded-full bg-sky-400 animate-pulse flex-shrink-0"></span>
              <p class="text-slate-700 text-xs font-semibold leading-tight">Formando nuevas generaciones de ortodoncistas</p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal order-1 lg:order-2" style="transition-delay:0.1s">
        <span class="text-sky-600 text-xs font-semibold tracking-widest uppercase">02 · Academia</span>
        <h3 class="font-display text-3xl sm:text-4xl font-bold text-slate-800 mt-3 leading-tight">
          Conocimiento que se <span class="gradient-text">enseña y se aplica</span>
        </h3>
        <p class="mt-5 text-slate-600 text-base leading-relaxed">
          Además de su trayectoria clínica, el Dr. Ramiro Mejía cuenta con
          <strong class="text-sky-700">15 años de experiencia como docente de posgrado</strong> de
          ortodoncia en la <strong class="text-slate-800">Universidad Autónoma de Manizales</strong>,
          lo que respalda su formación académica, su criterio clínico y su compromiso con la
          actualización constante y la enseñanza de la especialidad.
        </p>
      </div>
    </div>

    <!-- ============ 5. SECCIÓN: Tecnología + Enfoque ============ -->
    <div class="py-16 grid lg:grid-cols-2 gap-12 items-center">

      <!-- Texto + tarjetas -->
      <div class="reveal">
        <span class="text-sky-600 text-xs font-semibold tracking-widest uppercase">03 · Cómo trabajamos</span>
        <h3 class="font-display text-3xl sm:text-4xl font-bold text-slate-800 mt-3 leading-tight">
          Tratamientos con <span class="gradient-text">propósito</span>
        </h3>

        <div class="mt-8 flex flex-col gap-5">
          <div class="relative rounded-3xl p-7 bg-white border border-sky-100 hover:border-sky-300 hover:shadow-xl hover:shadow-sky-100/50 hover:-translate-y-1 transition-all duration-300">
            <h4 class="font-display text-xl font-bold text-slate-800 mb-3">Experiencia + Tecnología</h4>
            <p class="text-slate-600 text-sm leading-relaxed">
              Nuestro trabajo combina <strong class="text-slate-800">experiencia, conocimiento
              académico y tecnología moderna</strong> para ofrecer tratamientos de alta calidad,
              enfocados no solo en la estética de la sonrisa, sino también en
              <strong class="text-sky-700">la función, la salud oral y el bienestar</strong> de cada paciente.
            </p>
          </div>

          <div class="relative rounded-3xl p-7 bg-white border border-sky-100 hover:border-sky-300 hover:shadow-xl hover:shadow-sky-100/50 hover:-translate-y-1 transition-all duration-300">
            <h4 class="font-display text-xl font-bold text-slate-800 mb-3">Enfoque personalizado</h4>
            <p class="text-slate-600 text-sm leading-relaxed">
              Bajo la dirección del Dr. Ramiro Mejía, el equipo aborda desde casos simples hasta
              tratamientos complejos con un enfoque <strong class="text-sky-700">personalizado,
              responsable y basado en evidencia</strong>, acompañando a cada paciente en todo su
              proceso de transformación.
            </p>
          </div>
        </div>
      </div>

      <!-- Imagen cliente -->
      <div class="reveal flex justify-center" style="transition-delay:0.1s">
        <div class="relative group w-80 sm:w-96">
          <!-- Blob animado fondo -->
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-sky-300 via-amber-100 to-sky-400 opacity-30 blur-2xl group-hover:opacity-60 transition-all duration-700 animate-pulse"></div>

          <!-- Contenedor imagen -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-sky-200/60 ring-4 ring-white
                      transition-all duration-500 group-hover:scale-[1.03] group-hover:shadow-sky-300/70 group-hover:shadow-2xl">
            <img
              src="/images/cliente.webp"
              alt="Paciente satisfecho - Dr. Ramiro Mejía"
              loading="lazy"
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Overlay degradado sutil -->
            <div class="absolute inset-0 bg-gradient-to-t from-sky-900/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Badge flotante -->
            <div class="absolute bottom-4 left-4 right-4 flex items-center gap-2 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-2.5 shadow-lg
                        translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
              <span class="w-2.5 h-2.5 rounded-full bg-sky-400 animate-pulse flex-shrink-0"></span>
              <p class="text-slate-700 text-xs font-semibold leading-tight">Resultados que transforman sonrisas y vidas</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ============ 6. VALORES ============ -->
    <div class="py-16 pb-24 text-center reveal">
      <span class="text-sky-600 text-xs font-semibold tracking-widest uppercase">Nuestros valores</span>
      <h3 class="font-display text-2xl sm:text-3xl font-bold text-slate-800 mt-3 mb-10">
        Lo que nos define
      </h3>
      <div class="grid grid-cols-3 gap-3 sm:gap-4 max-w-2xl mx-auto">
        {[
          { label: 'Experiencia' },
          { label: 'Precisión' },
          { label: 'Tecnología' },
          { label: 'Ética' },
          { label: 'Compromiso' },
          { label: 'Innovación' },
        ].map((v) => (
          <span class="flex items-center justify-center px-5 py-3.5 text-base font-semibold rounded-full border border-sky-200 text-sky-700 bg-sky-50 hover:bg-sky-100 hover:border-sky-400 hover:shadow-md transition-all duration-300">
            {v.label}
          </span>
        ))}
      </div>
    </div>

  </div>
</section>
